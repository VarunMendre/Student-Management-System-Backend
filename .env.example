NODE_ENV=production
MYSQL_HOSTNAME=localhost
MYSQL_USERNAME=root
MYSQL_PASSWORD=change_me
MYSQL_DB=fee_management
PORT=5000
FRONTEND_URL=http://localhost:5173,https://asmfees.softlaser.in

# Cookie settings
# Use "none" + true  when frontend & backend are on DIFFERENT domains (cross-origin)
# Use "lax"  + true  when frontend & backend are on same domain or subdomains
# Use "lax"  + false for local HTTP development
COOKIE_SAME_SITE=none
COOKIE_SECURE=true
JWT_SECRET=replace_with_a_long_random_secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
OCR_POLL_INTERVAL_MS=5000
OCR_IDLE_LOG_EVERY=12
UPLOADS_ROOT=./uploads
FILE_STORAGE_DRIVER=local
S3_BUCKET_NAME=
S3_REGION=ap-south-1
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false
S3_SIGNED_URL_EXPIRES_SECONDS=900





